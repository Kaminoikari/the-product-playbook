[10.56, "o", "\r\n"]
[10.96, "o", "\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[11.26, "o", "\u001b[1m📍 直接實作模式  ｜  進度 S1 / S7\u001b[0m\r\n"]
[11.51, "o", "\u001b[32m▶️  S1：確認問題陳述\u001b[0m\u001b[90m（進行中）\u001b[0m\r\n"]
[11.71, "o", "\u001b[90m⬜ S2：PR-FAQ\u001b[0m\r\n"]
