[3.31, "o", "\u001b[1m\u001b[35m⚡ 直接實作模式啟動中...\u001b[0m\r\n"]
[3.71, "o", "\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[4.21, "o", "\u001b[36m📂 掃描專案目錄...\u001b[0m\r\n"]
[4.91, "o", "   \u001b[32m✓\u001b[0m \u001b[34mpackage.json\u001b[0m         → Node.js 18 · Express 4.18 · PostgreSQL\r\n"]
[5.71, "o", "   \u001b[32m✓\u001b[0m \u001b[34mprisma/schema.prisma\u001b[0m → 偵測到 \u001b[33mUser\u001b[0m、\u001b[33mOrder\u001b[0m、\u001b[33mProduct\u001b[0m 資料表\r\n"]
